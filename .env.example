# Database Configuration
# For local development, use SQLite (recommended for quick setup)
DATABASE_URL="file:./dev.db"

# For production, use PostgreSQL (example):
# DATABASE_URL="postgresql://username:password@localhost:5432/peblo_notes?schema=public"

# NextAuth Configuration
# URL where your app is hosted (change for production)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for JWT encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# OpenRouter AI API Key
# Get your free API key from: https://openrouter.ai/keys
# OpenRouter provides access to multiple AI models through a single API
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"

# Note: Never commit your actual .env file to version control!
# This is just a template. Copy this to .env and fill in your actual values.
