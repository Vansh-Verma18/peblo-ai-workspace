# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (keep .env.example)
.env
.env*.local
.env.production
.env.build

# database
dev.db
dev.db-journal
*.db
*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/migrations/

# test files
test-*.js
test-*.mjs

# temporary documentation (keep main docs)
*_FIX.md
*_SETUP*.md
QUICK_FIX.md
SIMPLE_SETUP.md
START_HERE.md
QUICKSTART.md
IMPORTANT_README.md
FILE_STRUCTURE.md
